@page
@model InvoiceApp.Pages.Invoices.IndexModel
@{
    ViewData["Title"] = "Fatura Listesi";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Fatura Listesi</h2>
        <a class="btn btn-primary" asp-page="/Invoices/Create">➕ Yeni Fatura</a>
    </div>

    <form method="get" class="mb-4">
        <div class="input-group shadow-sm">
            <input type="text" name="searchTerm" class="form-control" placeholder="Müşteri adı veya fatura no ile ara..." />
            <button class="btn btn-outline-primary" type="submit">Ara</button>
        </div>
    </form>

    <div class="card shadow-sm p-3">
        @if (Model.invoiceList.Count > 0)
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Fatura No</th>
                        <th>Müşteri</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th class="text-end">Toplam</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model.invoiceList)
                    {
                        <tr>
                            <td class="fw-bold">@invoice.Number</td>
                            <td>@invoice.ClientName</td>
                            <td>
                                @if (invoice.Status == "Paid")
                                {
                                    <span class="badge bg-success px-3">Ödendi</span>
                                }
                                else if (invoice.Status == "Pending")
                                {

                                    <span class="badge bg-warning text-dark px-3">Beklemede</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger px-3">İptal</span>
                                }
                            </td>
                            <td>@invoice.IssueDate?.ToString("dd.MM.yyyy")</td>
                            <td class="text-end fw-bold">@((invoice.UnitPrice * invoice.Quantity).ToString("N2")) ₺</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a class="btn btn-outline-info btn-sm" asp-page="/Invoices/Details" asp-route-id="@invoice.Id">Detay</a>
                                    <a class="btn btn-outline-danger btn-sm" asp-page="/Invoices/Delete" asp-route-id="@invoice.Id" onclick="return confirm('Silmek istediğine emin misin?')">Sil</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5">
                <div class="display-1 text-muted mb-3">📂</div>
                <h4 class="text-muted">Henüz fatura bulunamadı.</h4>
                <p>Yeni bir fatura ekleyerek başlayabilirsiniz.</p>
            </div>
        }
    </div>
</div>